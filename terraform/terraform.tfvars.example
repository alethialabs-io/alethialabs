# Tendril multi-region deployment configuration
# Copy to terraform.tfvars and fill in secrets.

project_name    = "tendril"
environment     = "dev"

# Add regions to scale out — each gets its own VPC, ECS cluster, and tendril worker.
regions         = ["eu-west-1"]

worker_mode     = "cloud-hosted"
trellis_url     = "https://adp.prod.itgix.eu"
tendril_version = "latest"

# Trellis API secret — used by workers to auto-register as tendrils.
trellis_api_secret = ""

# Supabase API — used by the Lambda scaler to query queued jobs.
supabase_url              = "https://YOUR_PROJECT.supabase.co"
supabase_service_role_key = ""

# Supabase S3 — Terraform state storage for provisioned vines.
supabase_s3_endpoint        = "https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3"
supabase_s3_region          = "eu-north-1"
supabase_storage_key_id     = ""
supabase_storage_secret_key = ""

# Infracost — cost estimation during plan jobs (optional).
infracost_api_key = ""

# Hardening — relax these for dev, tighten for production.
# ecr_image_tag_mutability     = "IMMUTABLE"   # default: MUTABLE
# ecr_force_delete             = false          # default: false
# secrets_recovery_window_days = 7              # default: 0 (immediate)
