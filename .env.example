# Alethia — environment template. Single source of truth for configuration.
#
#   cp .env.example .env && docker compose up -d
#
# Defaults below are pre-wired to the bundled docker-compose stack so a fresh
# checkout boots unedited. Override any value to point at managed services.

# ─────────────────────────────────────────────────────────────────────────────
# Object storage (S3-compatible) — Terraform/OpenTofu state + plan artifacts.
# Defaults target the bundled SeaweedFS service (see docker-compose.yml).
# For a hosted deploy, point these at AWS S3 / R2 / Garage and set
# ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=false (pre-provision the buckets out of band).
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_STORAGE_ENDPOINT=http://localhost:8333
ALETHIA_STORAGE_REGION=us-east-1
ALETHIA_STORAGE_ACCESS_KEY_ID=alethia
ALETHIA_STORAGE_SECRET_ACCESS_KEY=alethia-dev-secret
# App creates buckets it needs on first use (self-host default). Set false for managed S3.
ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=true
# Host port the bundled SeaweedFS S3 API is published on (compose only).
ALETHIA_STORAGE_PORT=8333

# ─────────────────────────────────────────────────────────────────────────────
# Application database (Postgres) — Drizzle connects directly.
# Defaults target the bundled `postgres` service (see docker-compose.yml).
# Two roles: the migration/service URL (superuser, bypasses RLS — used by
# runner/CLI/RPC paths) and the app URL (least-privilege, RLS-enforced — used by
# user-facing queries via withOwnerScope). The app role is created by the first
# migration. For a hosted deploy, point these at a managed Postgres.
# ─────────────────────────────────────────────────────────────────────────────
# Host port 5433 avoids colliding with a host-native Postgres on 5432.
ALETHIA_DATABASE_URL=postgres://alethia:alethia-dev-secret@localhost:5433/alethia
ALETHIA_APP_DATABASE_URL=postgres://alethia_app:alethia-app-dev-secret@localhost:5433/alethia
# Bundled-Postgres knobs (compose only).
ALETHIA_DB_USER=alethia
ALETHIA_DB_PASSWORD=alethia-dev-secret
ALETHIA_DB_NAME=alethia
ALETHIA_DB_PORT=5433
# Password for the least-privilege app role created by the first migration.
ALETHIA_APP_DB_PASSWORD=alethia-app-dev-secret

# AES-256-GCM key (32-byte base64) encrypting api_key integration secrets
# (Cloudflare token, Vault token, Docker Hub PAT, …) in connector_credentials.
# Required to connect pluggable integrations. Generate with: openssl rand -base64 32
# (dev-only sample below — generate a fresh key for any real deployment.)
ALETHIA_CRED_ENCRYPTION_KEY=/MkbZwf3J4Wv++DQILEGzBChaVvow+x7U1fv5f9HZpU=

# ─────────────────────────────────────────────────────────────────────────────
# Console (web) — app-level config.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to sign CLI device-code JWTs (shared with the runner). openssl rand -hex 32
CLI_JWT_SECRET=change-me-dev-only

# Better Auth. Secret signs sessions/cookies.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-dev-only
# Public origin Better Auth runs at; falls back to NEXT_PUBLIC_APP_URL if unset.
BETTER_AUTH_URL=http://localhost:3000

# Browse the database in a UI:
#   • pgweb (bundled):  docker compose --profile tools up -d pgweb  → http://localhost:8081
#   • Drizzle Studio:   pnpm -F console db:studio                   → https://local.drizzle.studio
ALETHIA_PGWEB_PORT=8081

# ─────────────────────────────────────────────────────────────────────────────
# Transactional email (AWS SES). Mail streams are isolated on dedicated sending
# subdomains so a reputation hit on one never poisons another — full setup
# runbook: docs → Self-Hosting → Email.
#   • auth.alethialabs.io       → AUTH_EMAIL_FROM (sign-in codes, verification, resets)
#   • mail.alethialabs.io       → EMAIL_FROM      (welcome, invites, notifications)
#   • marketing.alethialabs.io  → (future) bulk/marketing — its own SES identity + IP pool
#   • root alethialabs.io       → human/corporate mail only; the app never sends from it
# Set ALETHIA_SES_REGION to enable; the from-addresses must be verified SES
# identities (and the account out of the sandbox to mail arbitrary recipients).
# Credentials use ALETHIA_SES_* when set, else the AWS default chain (IAM role /
# AWS_* env). When unset, codes/emails are logged to the server console (dev).
# Quote the from-addresses — the angle brackets otherwise trip `source .env`.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_SES_REGION=
ALETHIA_SES_ACCESS_KEY_ID=
ALETHIA_SES_SECRET_ACCESS_KEY=
AUTH_EMAIL_FROM="Alethia <no-reply@auth.alethialabs.io>"
EMAIL_FROM="Alethia <hello@mail.alethialabs.io>"

# ─────────────────────────────────────────────────────────────────────────────
# OAuth providers (GitHub native; GitLab/Bitbucket via generic OAuth). Optional
# — only the providers you configure appear on the sign-in screen.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitLab instance for OAuth + API (default https://gitlab.com; set for self-hosted GitLab).
GITLAB_BASE_URL=
GITLAB_APPLICATION_ID=
GITLAB_SECRET=
BITBUCKET_KEY=
BITBUCKET_SECRET=

# Optional — Infracost API key enables cost estimation in the runner.
INFRACOST_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Runner — talks to the console over HTTP + S3 only.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_WEB_ORIGIN=http://localhost:3000
ALETHIA_RUNNER_MODE=self-hosted
# Set after registering the runner in the console (Phase B automates registration/seed).
ALETHIA_RUNNER_ID=
ALETHIA_RUNNER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Platform-internal API secret. Bearer token the cloud platform uses to call the
# console (runner auto-registration + the ECS scaler's /api/platform/queue probe).
# Only needed when running the AWS runner-fleet platform (infra/platform).
# ─────────────────────────────────────────────────────────────────────────────
RELEASE_API_SECRET=
