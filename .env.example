# Alethia — environment template. Single source of truth for configuration.
#
#   cp .env.example .env && docker compose up -d
#
# Defaults below are pre-wired to the bundled docker-compose stack so a fresh
# checkout boots unedited. Override any value to point at managed services.

# ─────────────────────────────────────────────────────────────────────────────
# Object storage (S3-compatible) — Terraform/OpenTofu state + plan artifacts.
# Defaults target the bundled SeaweedFS service (see docker-compose.yml).
# For a hosted deploy, point these at AWS S3 / R2 / Garage and set
# ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=false (pre-provision the buckets out of band).
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_STORAGE_ENDPOINT=http://localhost:8333
ALETHIA_STORAGE_REGION=us-east-1
ALETHIA_STORAGE_ACCESS_KEY_ID=alethia
ALETHIA_STORAGE_SECRET_ACCESS_KEY=alethia-dev-secret
# App creates buckets it needs on first use (self-host default). Set false for managed S3.
ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=true
# Host port the bundled SeaweedFS S3 API is published on (compose only).
ALETHIA_STORAGE_PORT=8333

# ─────────────────────────────────────────────────────────────────────────────
# Application database (Postgres) — Drizzle connects directly.
# Defaults target the bundled `postgres` service (see docker-compose.yml).
# Two roles: the migration/service URL (superuser, bypasses RLS — used by
# runner/CLI/RPC paths) and the app URL (least-privilege, RLS-enforced — used by
# user-facing queries via withOwnerScope). The app role is created by the first
# migration. For a hosted deploy, point these at a managed Postgres.
# ─────────────────────────────────────────────────────────────────────────────
# Host port 5433 avoids colliding with a host-native Postgres on 5432.
ALETHIA_DATABASE_URL=postgres://alethia:alethia-dev-secret@localhost:5433/alethia
ALETHIA_APP_DATABASE_URL=postgres://alethia_app:alethia-app-dev-secret@localhost:5433/alethia
# Bundled-Postgres knobs (compose only).
ALETHIA_DB_USER=alethia
ALETHIA_DB_PASSWORD=alethia-dev-secret
ALETHIA_DB_NAME=alethia
ALETHIA_DB_PORT=5433
# Password for the least-privilege app role created by the first migration.
ALETHIA_APP_DB_PASSWORD=alethia-app-dev-secret

# AES-256-GCM key (32-byte base64) encrypting secrets at rest: api_key connector
# secrets (Cloudflare token, Vault token, Docker Hub PAT, …) in connector_credentials
# AND alert-channel URL secrets (webhook/Slack/RocketChat incoming-webhook URLs).
# Required to connect pluggable connectors and to save secret-bearing alert channels.
# Generate with: openssl rand -base64 32
# (dev-only sample below — generate a fresh key for any real deployment.)
ALETHIA_CRED_ENCRYPTION_KEY=/MkbZwf3J4Wv++DQILEGzBChaVvow+x7U1fv5f9HZpU=

# ─────────────────────────────────────────────────────────────────────────────
# Console (web) — app-level config.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional — target for in-app "Docs" links (defaults to the bundled docs site).
DOCS_URL=
# Optional feature flag — set true to enable the design-spec canvas view.
NEXT_PUBLIC_CANVAS_ENABLED=false
# Secret used to sign CLI device-code JWTs (shared with the runner). openssl rand -hex 32
CLI_JWT_SECRET=change-me-dev-only

# Better Auth. Secret signs sessions/cookies.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-dev-only
# Public origin Better Auth runs at; falls back to NEXT_PUBLIC_APP_URL if unset.
BETTER_AUTH_URL=http://localhost:3000

# Browse the database in a UI:
#   • pgweb (bundled):  docker compose --profile tools up -d pgweb  → http://localhost:8081
#   • Drizzle Studio:   pnpm -F console db:studio                   → https://local.drizzle.studio
ALETHIA_PGWEB_PORT=8081

# ─────────────────────────────────────────────────────────────────────────────
# Edition & licensing (open-core). Self-managed (default) runs the community build;
# enterprise features unlock via a license flag or the org's billing record (hosted).
# ─────────────────────────────────────────────────────────────────────────────
# `hosted` → Stripe drives plans/entitlements per org. Unset/anything else → `self-managed`.
ALETHIA_DEPLOYMENT_MODE=self-managed
# Self-managed only: set `true` to grant enterprise entitlements instance-wide (a signed
# license). Leave unset for the community baseline.
ALETHIA_LICENSE_ACTIVE=

# ─────────────────────────────────────────────────────────────────────────────
# Billing (Stripe) — HOSTED only. Leave blank for self-managed/community; billing
# is simply disabled when STRIPE_SECRET_KEY is unset. The price IDs map plan tiers
# (and per-seat/usage meters) to your Stripe products. Read by lib/billing/config.ts.
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Set `true` to enable Stripe Tax on checkout/invoices.
STRIPE_TAX_ENABLED=
# Flat-tier subscription price IDs.
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
# Metered (usage) price IDs per tier.
STRIPE_PRICE_METER_TEAM=
STRIPE_PRICE_METER_BUSINESS=
STRIPE_PRICE_METER_ENTERPRISE=

# ─────────────────────────────────────────────────────────────────────────────
# Transactional email (AWS SES). Mail streams are isolated on dedicated sending
# subdomains so a reputation hit on one never poisons another — full setup
# runbook: docs → Self-Hosting → Email.
#   • auth.alethialabs.io       → AUTH_EMAIL_FROM (sign-in codes, verification, resets)
#   • mail.alethialabs.io       → EMAIL_FROM      (welcome, invites, notifications)
#   • marketing.alethialabs.io  → (future) bulk/marketing — its own SES identity + IP pool
#   • root alethialabs.io       → human/corporate mail only; the app never sends from it
# Set ALETHIA_SES_REGION to enable; the from-addresses must be verified SES
# identities (and the account out of the sandbox to mail arbitrary recipients).
# Credentials use ALETHIA_SES_* when set, else the AWS default chain (IAM role /
# AWS_* env). When unset, codes/emails are logged to the server console (dev).
# Quote the from-addresses — the angle brackets otherwise trip `source .env`.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_SES_REGION=
ALETHIA_SES_ACCESS_KEY_ID=
ALETHIA_SES_SECRET_ACCESS_KEY=
AUTH_EMAIL_FROM="Alethia <no-reply@auth.alethialabs.io>"
EMAIL_FROM="Alethia <hello@mail.alethialabs.io>"

# ─────────────────────────────────────────────────────────────────────────────
# OAuth providers (GitHub native; GitLab/Bitbucket via generic OAuth). Optional
# — only the providers you configure appear on the sign-in screen.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitLab instance for OAuth + API (default https://gitlab.com; set for self-hosted GitLab).
GITLAB_BASE_URL=
GITLAB_APPLICATION_ID=
GITLAB_SECRET=
BITBUCKET_KEY=
BITBUCKET_SECRET=

# Optional — Infracost API key enables cost estimation in the runner.
INFRACOST_API_KEY=

# Optional — Vercel AI Gateway key enables the design-spec AI assistant (Ask AI).
# Without it the assistant route returns 503 and the UI shows a "not configured" state.
# Get one at https://vercel.com/docs/ai-gateway. Read server-side via next-runtime-env.
AI_GATEWAY_API_KEY=

# Remote MCP server (B7) — exposes the agent's read + scan tools to Claude / claude.ai
# connectors at <BETTER_AUTH_URL>/api/mcp over OAuth 2.1 (Better Auth's mcp() plugin;
# no extra config — it reuses BETTER_AUTH_SECRET/URL and the OAuth tables). Add the
# connector in claude.ai with the /api/mcp URL; it auto-discovers auth via
# /.well-known/oauth-{authorization-server,protected-resource}. Self-host (no Stripe)
# = always enabled; hosted = gated on the org's AI entitlement.

# ─────────────────────────────────────────────────────────────────────────────
# Runner — talks to the console over HTTP + S3 only.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_WEB_ORIGIN=http://localhost:3000
ALETHIA_RUNNER_MODE=self-hosted
# Set after registering the runner in the console, OR leave blank + set the bootstrap
# token below so the runner self-registers (managed fleet VMs).
ALETHIA_RUNNER_ID=
ALETHIA_RUNNER_TOKEN=
# Concurrent jobs per runner (N worker subprocesses). Default 1.
# ALETHIA_RUNNER_SLOTS=

# ─────────────────────────────────────────────────────────────────────────────
# Managed fleet (hosted only) — the in-app scaler provisions warm runners on a
# cloud FleetProvider. Default (unset) = no managed fleet; the scaler is a no-op.
# ─────────────────────────────────────────────────────────────────────────────
# FLEET_PROVIDER=hcloud
# Warm pools are now managed in the DB (fleet_pools) via the console Fleet page. FLEET_POOLS
# is DEPRECATED — it is imported once into an empty fleet_pools table on first boot (seed),
# then ignored. Prefer creating/editing pools in the UI.
# FLEET_POOLS=[{"provider":"aws","warmMin":1,"max":10,"slotsPerRunner":1,"scaleDownGraceTicks":5}]
# HCLOUD_TOKEN=
# HCLOUD_SERVER_TYPE=cax21
# HCLOUD_LOCATION=fsn1
# HCLOUD_IMAGE=ubuntu-24.04
# HCLOUD_SSH_KEYS=
# FLEET_RUNNER_IMAGE_TAG=latest
# Seconds a freshly-booted fleet VM is exempt from scale-down (cloud-init grace).
# FLEET_BOOT_GRACE_SECONDS=
# Shared token fleet VMs present to self-register (lower-privilege than RELEASE_API_SECRET).
# ALETHIA_RUNNER_BOOTSTRAP_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Platform-internal API secret. Bearer token the platform uses to call the console
# (runner registration). Only needed for platform-internal automation.
# ─────────────────────────────────────────────────────────────────────────────
RELEASE_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Internal cron trigger (optional). Bearer secret that enables the manual
# maintenance endpoints (alert-delivery sweep /api/internal/alerts/sweep, fleet
# scaler). Unset = those endpoints fail closed. NOTE: the in-process alert scheduler
# and job-recovery loops run regardless — this is only for an external cron poke.
#   openssl rand -hex 32
ALETHIA_CRON_SECRET=
