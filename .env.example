# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  Alethia — environment template (community / self-host)                      ║
# ╚════════════════════════════════════════════════════════════════════════════╝
#
#   cp .env.example .env && docker compose up -d
#
# Every value below is PRE-WIRED to the bundled docker-compose stack, so a fresh
# checkout boots unedited at http://localhost. Before exposing it to anyone, do
# two things: (1) regenerate the three [REQUIRED] secrets in §1, and (2) point
# the DB/storage at real services if you're not using the bundled ones.
#
# Legend:
#   [REQUIRED]    set this — generate a real value before any real deployment
#   [DEV-DEFAULT] works as-is for local dev; change for production
#   [OPTIONAL]    leave blank to keep the feature OFF
#
# This file covers the COMMUNITY build only. Enterprise (organizations, SSO,
# OpenFGA, license) and Alethia-Labs Hosted billing (Stripe, managed fleet) vars
# are intentionally omitted — see docs → Editions and docs → Self-Hosting.


# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE SECRETS  [REQUIRED]
# The bundled stack ships dev placeholders so it boots; generate fresh values for
# anything beyond your laptop. These three are the only secrets you MUST set.
# ─────────────────────────────────────────────────────────────────────────────
# Better Auth — signs sessions/cookies.        Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-dev-only
# Signs CLI device-code JWTs (shared with the runner). Generate: openssl rand -hex 32
CLI_JWT_SECRET=change-me-dev-only
# AES-256-GCM key (32-byte base64) encrypting secrets at rest: api_key connector
# secrets (Cloudflare/Vault tokens, Docker Hub PAT, …) in connector_credentials AND
# alert-channel webhook URLs. Required to connect connectors / save secret alert
# channels.                                     Generate: openssl rand -base64 32
# (dev-only sample below — replace for any real deployment.)
ALETHIA_CRED_ENCRYPTION_KEY=/MkbZwf3J4Wv++DQILEGzBChaVvow+x7U1fv5f9HZpU=


# ─────────────────────────────────────────────────────────────────────────────
# 2. APP / WEB
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED] Public origin of the console. localhost for dev; your https:// URL in prod
# (used by OAuth callbacks, emails, API redirects, MCP).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [OPTIONAL] Origin Better Auth runs at; falls back to NEXT_PUBLIC_APP_URL if unset.
BETTER_AUTH_URL=http://localhost:3000
# [OPTIONAL] Feature flag — set true to enable the design-spec canvas view.
NEXT_PUBLIC_CANVAS_ENABLED=false
# [OPTIONAL] Target for in-app "Docs" links (defaults to the bundled docs site).
DOCS_URL=
# [DEV-DEFAULT] Host port for the optional bundled DB UI:
#   docker compose --profile tools up -d pgweb  → http://localhost:8081
ALETHIA_PGWEB_PORT=8081
# [DEV-DEFAULT] Self-managed is the community default; the app runs the community
# build. (`hosted` enables Stripe billing — an Alethia-Labs SaaS concern; see docs.)
ALETHIA_DEPLOYMENT_MODE=self-managed


# ─────────────────────────────────────────────────────────────────────────────
# 3. DATABASE (Postgres)  [DEV-DEFAULT]
# Defaults target the bundled `postgres` service. Two roles: the migration/service
# URL (bypasses RLS — runner/CLI/RPC paths) and the app URL (least-privilege,
# RLS-enforced — user-facing queries). The app role is created by the first
# migration. Point these at a managed Postgres for a hosted deploy.
# Host port 5433 avoids colliding with a host-native Postgres on 5432.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_DATABASE_URL=postgres://alethia:alethia-dev-secret@localhost:5433/alethia
ALETHIA_APP_DATABASE_URL=postgres://alethia_app:alethia-app-dev-secret@localhost:5433/alethia
# Bundled-Postgres knobs (compose only).
ALETHIA_DB_USER=alethia
ALETHIA_DB_PASSWORD=alethia-dev-secret
ALETHIA_DB_NAME=alethia
ALETHIA_DB_PORT=5433
# Password for the least-privilege app role created by the first migration.
ALETHIA_APP_DB_PASSWORD=alethia-app-dev-secret
# [OPTIONAL] Connection-pool tuning (postgres-js). Defaults: max 10, idle 20s.
# ALETHIA_DB_POOL_MAX=10
# ALETHIA_DB_IDLE_TIMEOUT=20


# ─────────────────────────────────────────────────────────────────────────────
# 4. OBJECT STORAGE (S3-compatible)  [DEV-DEFAULT]
# Terraform/OpenTofu state + plan artifacts. Defaults target the bundled SeaweedFS.
# For a hosted deploy, point at AWS S3 / R2 / Garage and set
# ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=false (pre-provision the buckets out of band).
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_STORAGE_ENDPOINT=http://localhost:8333
ALETHIA_STORAGE_REGION=us-east-1
ALETHIA_STORAGE_ACCESS_KEY_ID=alethia
ALETHIA_STORAGE_SECRET_ACCESS_KEY=alethia-dev-secret
# App creates the buckets it needs on first use (self-host default). false for managed S3.
ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=true
# Host port the bundled SeaweedFS S3 API is published on (compose only).
ALETHIA_STORAGE_PORT=8333


# ─────────────────────────────────────────────────────────────────────────────
# 5. OAUTH PROVIDERS  [OPTIONAL]
# Only the providers you configure appear on the sign-in screen. (GitHub & Google
# are native; GitLab & Bitbucket via the generic OAuth plugin.) With none set,
# sign-in falls back to email OTP.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitLab instance for OAuth + API (default https://gitlab.com; set for self-hosted GitLab).
GITLAB_BASE_URL=
GITLAB_APPLICATION_ID=
GITLAB_SECRET=
BITBUCKET_KEY=
BITBUCKET_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# 6. TRANSACTIONAL EMAIL (AWS SES)  [OPTIONAL]
# Unset → sign-in codes / emails are logged to the server console (fine for dev).
# Set ALETHIA_SES_REGION to enable; from-addresses must be verified SES identities
# (account out of the SES sandbox to mail arbitrary recipients). Credentials use
# ALETHIA_SES_* when set, else the AWS default chain (IAM role / AWS_* env;
# AWS_REGION is the region fallback). Quote the from-addresses — the angle brackets
# otherwise trip `source .env`. Full runbook: docs → Self-Hosting → Email.
# ─────────────────────────────────────────────────────────────────────────────
ALETHIA_SES_REGION=
ALETHIA_SES_ACCESS_KEY_ID=
ALETHIA_SES_SECRET_ACCESS_KEY=
AUTH_EMAIL_FROM="Alethia <no-reply@auth.alethialabs.io>"
EMAIL_FROM="Alethia <hello@mail.alethialabs.io>"


# ─────────────────────────────────────────────────────────────────────────────
# 7. AI ASSISTANT & COST  [OPTIONAL]
# ─────────────────────────────────────────────────────────────────────────────
# Vercel AI Gateway key enables the design-spec AI assistant (Ask AI). Without it
# the assistant route returns 503 and the UI shows a "not configured" state.
# Get one at https://vercel.com/docs/ai-gateway. (On Vercel, VERCEL_OIDC_TOKEN can
# be used instead of a key.)
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
# Curated model override (allowlisted: anthropic/claude-sonnet-4.6,
# anthropic/claude-opus-4.8). Defaults to Sonnet 4.6.
# AI_MODEL=anthropic/claude-sonnet-4.6
# Infracost API key enables cost estimation in the runner.
INFRACOST_API_KEY=
#
# Remote MCP server: exposes the agent's read + scan tools to Claude / claude.ai
# at <BETTER_AUTH_URL>/api/mcp over OAuth 2.1 (Better Auth's mcp() plugin — no
# extra config; reuses BETTER_AUTH_SECRET/URL). Self-host = always enabled. Add
# the connector in claude.ai with the /api/mcp URL.


# ─────────────────────────────────────────────────────────────────────────────
# 8. SELF-HOSTED RUNNER  [OPTIONAL]
# Only needed if you run provisioning jobs. The runner talks to the console over
# HTTP + S3 only. Skip this whole section to just use the web UI.
# ─────────────────────────────────────────────────────────────────────────────
# Console URL the runner calls back to (must be reachable from where the runner runs).
ALETHIA_WEB_ORIGIN=http://localhost:3000
# Operator: `self` (runs in your cloud with native perms) — the self-host default.
# (Legacy ALETHIA_RUNNER_MODE=self-hosted still works as a back-compat fallback.)
ALETHIA_RUNNER_OPERATOR=self
# Credentials from registering the runner in the console (Settings → Runners).
ALETHIA_RUNNER_ID=
ALETHIA_RUNNER_TOKEN=
# Concurrent jobs per runner (N worker subprocesses). Default 1.
# ALETHIA_RUNNER_SLOTS=1
# Restrict this runner to specific clouds (comma-separated, e.g. "aws,gcp").
# Empty = any provider (the full multi-cloud image).
# ALETHIA_RUNNER_PROVIDERS=
#
# Managed runner-fleet autoscaling (FLEET_*): the in-app scaler can provision warm
# runner VMs on Hetzner. See docs → Self-Hosting → Configuration.
#
# Carry-your-own cloud tokens for "token clouds" (only when this runner provisions
# them). AWS / GCP / Azure use per-job role assumption instead — no static keys here.
# HCLOUD_TOKEN=
# DIGITALOCEAN_ACCESS_TOKEN=
# CIVO_TOKEN=
# ALETHIA_ALIBABA_ACCESS_KEY_ID=
# ALETHIA_ALIBABA_ACCESS_KEY_SECRET=
# ALETHIA_ALIBABA_REGION=cn-hangzhou
#
# Platform-internal secret — Bearer token used for runner registration / release
# APIs. Needed only if you wire up runner self-registration. openssl rand -hex 32
RELEASE_API_SECRET=
# [OPTIONAL] Bearer secret enabling the manual maintenance endpoints (alert-delivery
# sweep, fleet scaler). Unset = those endpoints fail closed; the in-process alert
# scheduler and job-recovery loops run regardless. openssl rand -hex 32
ALETHIA_CRON_SECRET=
