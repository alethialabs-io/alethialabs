# Production runtime env for the bundle. This file's filled content is the value
# of the GitHub secret **ALETHIA_DOTENV** (the deploy-app workflow writes it to
# /opt/alethia/.env on the box). PLACEHOLDERS ONLY here — never commit real values.
#
# Internal service URLs (Postgres/SeaweedFS) are set by deploy/prod/docker-compose.prod.yml
# + the base compose, so they're intentionally NOT here. ALETHIA_IMAGE_TAG is
# appended by the workflow (the commit SHA to pull).

# ── App / ingress ────────────────────────────────────────────────────────────
# Your domain (Caddy gets TLS for it automatically). Leave ALETHIA_DOMAIN empty
# to serve plain HTTP on :80 (IP-only test).
ALETHIA_DOMAIN=alethia.example.com
ALETHIA_ACME_EMAIL=you@example.com
NEXT_PUBLIC_APP_URL=https://alethia.example.com
CLI_JWT_SECRET=__GENERATE__            # openssl rand -hex 32 (shared with the runner)

# ── Database (bundled Postgres) ──────────────────────────────────────────────
ALETHIA_DB_USER=alethia
ALETHIA_DB_NAME=alethia
ALETHIA_DB_PASSWORD=__GENERATE__
ALETHIA_APP_DB_PASSWORD=__GENERATE__

# ── Object storage (bundled SeaweedFS, internal-only) ────────────────────────
# Must match deploy/seaweedfs/s3.json. Internal network → low risk, but set real
# values for production.
ALETHIA_STORAGE_ACCESS_KEY_ID=__SET__
ALETHIA_STORAGE_SECRET_ACCESS_KEY=__SET__
ALETHIA_STORAGE_AUTO_CREATE_BUCKETS=true

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=__SET__

# ── OAuth providers ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=__SET__
GITHUB_CLIENT_SECRET=__SET__
GITLAB_APPLICATION_ID=
GITLAB_SECRET=
BITBUCKET_KEY=
BITBUCKET_SECRET=

# ── Runner ───────────────────────────────────────────────────────────────────
ALETHIA_WORKER_MODE=self-hosted

# ── Platform-internal API secret (only for the infra/platform runner fleet) ──
# Bearer token for tendril auto-registration + the ECS scaler's queue probe.
RELEASE_API_SECRET=__SET__
