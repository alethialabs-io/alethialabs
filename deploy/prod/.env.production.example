# Production runtime env — CATALOG of the AWS Secrets Manager vault.
#
# There is NO ALETHIA_DOTENV blob and NO GitHub Actions secrets. Every key below is a
# JSON field in the single Secrets Manager secret **alethia/prod/env** (acct
# 270587882865, eu-central-1). `deploy-console` reads it via OIDC (role
# alethia-deploy-reader) and ASSEMBLES /opt/alethia/.env on the box; internal service
# URLs (Postgres/SeaweedFS) come from the compose files. `ALETHIA_IMAGE_TAG` = deployed SHA.
#
# Provisioning legend:
#   [auto]  generated once by scripts/bootstrap-secrets.sh (never typed)
#   [chain] written by infra-cp-hetzner apply (OIDC PutSecretValue)
#   [ext]   external — you put it in deploy/prod/secrets.local.env once (see
#           secrets.local.env.example) → bootstrap-secrets.sh merges it into the vault
#   [const] hardcoded by the deploy assembler / a repo Actions VARIABLE (not a secret)

# ── App / ingress ────────────────────────────────────────────────────────────
# `PUBLIC_APP_URL` is a repo Actions VARIABLE (set by infra/github); it drives all four.
PUBLIC_APP_URL=https://alethialabs.io        # [const/var] → NEXT_PUBLIC_APP_URL / BETTER_AUTH_URL / NEXT_PUBLIC_SITE_URL / NEXT_PUBLIC_LEGAL_URL
ALETHIA_DEPLOYMENT_MODE=hosted               # [const] this box IS hosted; unset ⇒ deploymentMode() = self-managed (mis-toggles feedback/runner/fleet UI)
BETTER_AUTH_SECRET=                          # [auto] openssl rand -base64 32
CLI_JWT_SECRET=                              # [auto] openssl rand -hex 32
ALETHIA_CRED_ENCRYPTION_KEY=                 # [auto] base64/32B (lib/crypto/secrets.ts)

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
TUNNEL_TOKEN=                                # [chain] infra-cp-hetzner: tofu output → vault

# ── Analytics: PostHog (prod suite) + OpenReplay Cloud (optional OSS replay) ──
NEXT_PUBLIC_OPENREPLAY_PROJECT_KEY=          # [ext]  OpenReplay Cloud project key (openreplay.com, EU region)
NEXT_PUBLIC_OPENREPLAY_INGEST=               # [ext]  optional — empty = OpenReplay Cloud default; set for EU/self-host
NEXT_PUBLIC_POSTHOG_KEY=                      # [ext]  PostHog project API key (posthog.com, EU) — the prod suite
NEXT_PUBLIC_POSTHOG_HOST=                     # [ext]  optional — empty = https://eu.i.posthog.com

# ── Database (bundled Postgres) — DB URLs built by compose from these ────────
ALETHIA_DB_PASSWORD=                         # [auto]
ALETHIA_APP_DB_PASSWORD=                     # [auto]
OPENFGA_DB_PASSWORD=                         # [auto] (only if OpenFGA enabled)

# ── Object storage (bundled SeaweedFS) — deploy renders s3.json from these ───
ALETHIA_STORAGE_ACCESS_KEY_ID=               # [auto]
ALETHIA_STORAGE_SECRET_ACCESS_KEY=           # [auto]

# ── Managed runner fleet (in-app scaler → Hetzner Cloud) ─────────────────────
# FLEET_PROVIDER / image tag / slots are [const] in the assembler. The runtime fleet
# uses a SEPARATE Hetzner project token from the control-plane CI token.
HCLOUD_FLEET_TOKEN=                          # [ext]  → written as HCLOUD_TOKEN in .env
HCLOUD_SSH_KEYS=                             # [ext]  comma-separated Hetzner SSH key IDs
HCLOUD_SERVER_TYPE=cax21                     # [ext/opt] default cax21
ALETHIA_RUNNER_BOOTSTRAP_TOKEN=              # [auto] fleet self-registration bearer
ALETHIA_CRON_SECRET=                         # [auto] maintenance-endpoint bearer
RELEASE_API_SECRET=                          # [auto] runner/CLI release-metadata bearer
ALETHIA_OIDC_SIGNING_KEY=                    # [auto] base64(PKCS8 RSA) — workload-identity issuer (keyless Azure/Alibaba)
ALETHIA_OIDC_SIGNING_KEY_PREVIOUS=           # [auto/rotation] published-but-not-signing 2nd key; set ONLY mid-rotation by scripts/rotate-oidc-key.sh, empty otherwise

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# github/google = native social; gitlab/bitbucket = genericOAuth (callback /api/auth/oauth2/callback/:id).
GITHUB_CLIENT_ID=                            # [ext]
GITHUB_CLIENT_SECRET=                        # [ext]
GOOGLE_CLIENT_ID=                            # [ext]
GOOGLE_CLIENT_SECRET=                        # [ext]
GITLAB_APPLICATION_ID=                       # [ext]
GITLAB_SECRET=                               # [ext]
BITBUCKET_KEY=                               # [ext]
BITBUCKET_SECRET=                            # [ext]

# ── Managed cloud platform identity (optional) — SERVER-SIDE connection health/inventory ──────
# All four managed clouds are KEYLESS and issuer-direct: the customer's IAM role / WIF pool / RAM OIDC
# provider trusts Alethia's OIDC issuer (ALETHIA_OIDC_SIGNING_KEY) directly — no platform AWS account, no
# static key. AWS, GCP, and Alibaba need NOTHING here; availability tracks the issuer key alone. Only Azure
# needs an app id (below). Token clouds need none.
ALETHIA_AZURE_CLIENT_ID=                     # [ext] KEYLESS: one multi-tenant Entra app, OIDC-federated (no secret); connect UI receives it server-side (no NEXT_PUBLIC_ copy)
# Alibaba is KEYLESS + account-free (AssumeRoleWithOIDC via the OIDC issuer) — no AccessKey to set.

# ── AI assistant (optional) ──────────────────────────────────────────────────
# Direct-to-provider (no Vercel AI Gateway). Set ANTHROPIC_API_KEY ⇒ AI runs at the **Free tier** in
# prod (lib/config/ai.ts isAiConfigured); unset ⇒ AI off (routes 503). OPENAI_API_KEY only for openai/*
# overrides. Paid AI tiers stay dark until STRIPE_PRICE_AI_* below are set.
ANTHROPIC_API_KEY=                           # [ext] enables AI Free tier in prod; unset ⇒ AI off
# OPENAI_API_KEY=                            # [ext/opt] only for openai/* model overrides

# ── Stripe (optional, hosted billing) ────────────────────────────────────────
STRIPE_SECRET_KEY=                           # [ext]
STRIPE_WEBHOOK_SECRET=                       # [ext]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=          # [ext] (pk_… safe to expose)
STRIPE_PRICE_TEAM=                           # [ext]
STRIPE_PRICE_METER_TEAM=                     # [ext] metered price for runner-minutes (Team); unset ⇒ usage never charged
STRIPE_PRICE_METER_ENTERPRISE=               # [ext] metered price for runner-minutes (Enterprise)
STRIPE_PRICE_AI_PLUS=                        # [ext] standalone AI Plus subscription price; unset ⇒ AI Plus tier dark
STRIPE_PRICE_AI_MAX=                         # [ext] standalone AI Max subscription price; unset ⇒ AI Max tier dark
STRIPE_TAX_ENABLED=                          # [opt] set =true ONLY after Stripe Tax origin+registrations configured; empty ⇒ automatic_tax off (default)
ODOO_INVOICE_URL=                            # [ext/opt] Odoo фактура (legal invoice-of-record) endpoint; unset ⇒ Stripe PDF used as invoice
ODOO_INVOICE_TOKEN=                          # [ext/opt] bearer for the Odoo фактура endpoint; needs URL too (both must be set to activate)

# ── Support (optional) ───────────────────────────────────────────────────────
SUPPORT_SLACK_WEBHOOK_URL=                   # [ext] staff Slack ping on new case/reply; unset ⇒ no-op
NEXT_PUBLIC_COMMUNITY_URL=                   # [ext] community link on the support page; unset ⇒ card disabled
SUPPORT_STAFF_EMAILS=                        # [ext] comma-separated staff allowlist for admin.alethialabs.io (Cloudflare Access gate)
NEXT_PUBLIC_CONSOLE_URL=https://alethialabs.io  # [derived] set by the deploy assembler = PUBLIC_APP_URL; admin case deep-links target it
PLATFORM_PROVISION_SECRET=                    # [ext] dedicated bearer for apps/admin → console provisioning routes (NOT the cron secret); unset ⇒ operator plane inert
PLATFORM_SYSTEM_USER_EMAIL=                   # [ext] permanent system user = inviterId on operator-issued owner invitations (e.g. platform@alethialabs.io)
PLATFORM_ADMIN_EMAILS=                        # [ext] ACT-capable operator allowlist for apps/admin /orgs (DISTINCT from SUPPORT_STAFF_EMAILS)
STRIPE_ENTERPRISE_PRODUCT_ID=                 # [ext] Stripe Product id for enterprise line items (Stripe onboarding path)

# ── Email (AWS SES, optional) ────────────────────────────────────────────────
# From-addresses are [const] in the assembler.
ALETHIA_SES_REGION=                          # [ext] empty → emails logged, not sent
ALETHIA_SES_ACCESS_KEY_ID=                   # [ext]
ALETHIA_SES_SECRET_ACCESS_KEY=               # [ext]

# ── Operability suite (all OPTIONAL, default-off; the deploy assembler emits each tolerantly) ────
# Self-hosted observability — unset ⇒ the SDK/exporter never initializes (no-op, zero cost).
OTEL_EXPORTER_OTLP_ENDPOINT=                 # [ext] OTLP collector URL for traces+metrics; unset ⇒ tracing off
OTEL_SERVICE_NAME=                           # [ext/opt] service.name on spans (default "alethia-console")
SENTRY_DSN=                                  # [ext] GlitchTip/Sentry DSN for error tracking; unset ⇒ errors off
SENTRY_ENVIRONMENT=                          # [ext/opt] Sentry environment tag (e.g. "production")
SENTRY_TRACES_SAMPLE_RATE=                   # [ext/opt] Sentry perf sample rate (0..1); default 0
ALETHIA_PLATFORM_ALERT_ORG_ID=               # [ext] org that background-loop-degraded alerts fan out to; unset ⇒ logged only, no channel
ALETHIA_LOG_LEVEL=                           # [ext/opt] console log level (default info); DEBUG is stdout-only
# Break-glass privileged recovery — DEFAULT-OFF; the surface 404s unless ENABLED="true".
ALETHIA_BREAKGLASS_ENABLED=                  # [ext] "true" arms the break-glass console/API; anything else ⇒ 404
BREAKGLASS_OPERATORS=                        # [ext] comma-separated operator allowlist (DISTINCT from SUPPORT_STAFF_EMAILS)
BREAKGLASS_ACCESS_PROXY_SECRET=              # [ext] shared secret to trust the CF-Access email header; unset ⇒ header path disabled (CLI-JWT only)
ALETHIA_BREAKGLASS_ORPHAN_CLEAN_ENABLED=     # [ext] arms orphan-clean (still returns 501 not-implemented even when armed)
# Reconcile/GC tunables — safe code defaults; set only to override.
ALETHIA_CONVERGE_MIN_AGE_MINUTES=            # [ext/opt] env-convergence backstop min-age gate (default 5)
ALETHIA_JOB_LOG_RETENTION_DAYS=              # [ext/opt] job_logs retention before GC (default 30)
ALETHIA_FLEET_ACTION_RETENTION_DAYS=         # [ext/opt] fleet_actions ledger retention (default 90)

# ── Infra-only vault keys (NOT in .env; used by infra-cp-hetzner / infra-status) ──
#   CLOUDFLARE_API_TOKEN / CLOUDFLARE_ZONE_ID / CLOUDFLARE_ACCOUNT_ID   [ext]
#   HCLOUD_TOKEN            [ext]  control-plane Hetzner token (distinct from fleet)
#   DEPLOY_SSH_PRIVATE_KEY / DEPLOY_SSH_PUBLIC_KEY  [auto] ed25519 keypair generated by bootstrap-secrets.sh
#   DEPLOY_HOST             [chain] infra-cp-hetzner: tofu output -raw server_ipv4
#   ACME_EMAIL             [ext/opt] only for the infra/status box
