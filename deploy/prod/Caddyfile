# Production ingress — automatic HTTPS via Let's Encrypt.
# Domain + ACME email come from the environment so any self-hoster can use it:
#   ALETHIA_DOMAIN=app.example.com  ALETHIA_ACME_EMAIL=you@example.com
# If ALETHIA_DOMAIN is unset it falls back to ":80" (plain HTTP, no TLS) — handy
# for a quick IP-only test.
{
	email {$ALETHIA_ACME_EMAIL}
}

{$ALETHIA_DOMAIN::80} {
	encode zstd gzip
	handle /docs* {
		reverse_proxy docs:3000
	}
	handle /blog* {
		reverse_proxy blog:3000
	}
	handle {
		reverse_proxy app:3000
	}
}
