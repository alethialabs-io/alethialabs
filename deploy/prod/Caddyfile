# Production ingress — automatic HTTPS via Let's Encrypt.
# Domain + ACME email come from the environment so any self-hoster can use it:
#   ALETHIA_DOMAIN=app.example.com  ALETHIA_ACME_EMAIL=you@example.com
# If ALETHIA_DOMAIN is unset it falls back to ":80" (plain HTTP, no TLS) — handy
# for a quick IP-only test.
{
	email {$ALETHIA_ACME_EMAIL}
}

{$ALETHIA_DOMAIN::80} {
	encode zstd gzip
	handle /docs* {
		reverse_proxy docs:3000
	}
	handle /blog* {
		reverse_proxy blog:3000
	}
	# Marketing zone (hosted-only — OSS ships none). To serve the marketing app behind
	# Caddy, run a `marketing` service and drop a `marketing.caddy` beside this file
	# (copy deploy/caddy/marketing.caddy.example), then uncomment the import below. It
	# mirrors apps/console/microfrontends.json and must stay before the catch-all.
	# import marketing*.caddy
	handle {
		reverse_proxy app:3000
	}
}
