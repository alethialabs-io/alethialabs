# EXTERNALS — the values that can't be generated (third-party registration). Copy to
# `deploy/prod/secrets.local.env` (GITIGNORED), fill in, then run:
#     ./scripts/bootstrap-secrets.sh
# It merges these into the ONE Secrets Manager secret `alethia/prod/env`. Nothing here
# goes into GitHub. Do NOT quote values — everything after the first `=` is the value.
# Internal secrets (BETTER_AUTH_SECRET, DB passwords, …) are auto-generated — omit them.
#
# GO-LIVE MAP — what's needed for what:
#   REQUIRED to boot:  CLOUDFLARE_* + HCLOUD_TOKEN + HCLOUD_FLEET_TOKEN + HCLOUD_SSH_KEYS + PUBLIC_APP_URL.
#   OPTIONAL features (leave blank to keep off): the cloud connectors, Stripe billing, SES email,
#     support Slack, analytics. Each section below says what unset does.
#   The managed-cloud connector values (Azure app id, AWS role ARN) don't exist until you run a ONE-TIME
#   setup — see docs → Self-hosting → Managed cloud connectors (/self-hosting/managed-cloud-connectors).
#   Every key here is [ext]; commented (#) keys are optional overrides with a working default.

# ── Cloudflare (tunnel + DNS) ────────────────────────────────────────────────
# Token scopes: Account·Cloudflare Tunnel:Edit, Zone·DNS:Edit, Zone·Zone:Read,
# Account·Account Settings:Read (zone = alethialabs.io).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── Hetzner (two separate projects/tokens) ───────────────────────────────────
HCLOUD_TOKEN=            # control-plane project, Read & Write
HCLOUD_FLEET_TOKEN=      # fleet project, Read & Write
HCLOUD_SSH_KEYS=         # comma-separated Hetzner SSH key IDs for fleet VMs
# HCLOUD_SERVER_TYPE=cax21   # optional — fleet VM size; default cax21

# NOTE: the CI→box deploy SSH keypair is AUTO-GENERATED by bootstrap-secrets.sh (ed25519)
# and stored in the vault — you don't provide it. (Bring-your-own: run with
# DEPLOY_SSH_KEY_FILE=./your_key to import an existing private key instead.)

# ── App origin ───────────────────────────────────────────────────────────────
PUBLIC_APP_URL=https://alethialabs.io

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# GitHub OAuth App callback: https://alethialabs.io/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth client callback: https://alethialabs.io/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitLab application (genericOAuth). Redirect URI: https://alethialabs.io/api/auth/oauth2/callback/gitlab
GITLAB_APPLICATION_ID=
GITLAB_SECRET=
# Bitbucket OAuth consumer (genericOAuth). Callback URL: https://alethialabs.io/api/auth/oauth2/callback/bitbucket
BITBUCKET_KEY=
BITBUCKET_SECRET=

# ── Managed cloud platform identity (optional) ───────────────────────────────
# All four managed clouds are KEYLESS — federated via Alethia's own OIDC issuer (no static keys).
# AWS + GCP hub through ONE platform AWS identity: set the role ARN and you light up AWS **and GCP**
# (GCP rides the same identity). Leave blank → those tiles show "Not enabled on this instance". Token
# clouds (Hetzner/DO/Civo) need nothing.
# See docs → Self-hosting → Managed cloud connectors, and infra/connector-platform/aws.
# AWS (also powers GCP): apply infra/connector-platform/aws ONCE (creates an IAM OIDC provider + a
# least-priv role trusting the Alethia issuer — NO access key), then set its role-ARN output here. The
# console federates in via AssumeRoleWithWebIdentity and refreshes AWS_* at runtime for google-auth.
# HOW: `cd infra/connector-platform/aws && tofu apply` (in account 270587882865) → the `assumer_role_arn` output.
ALETHIA_AWS_PLATFORM_ROLE_ARN=
# Platform AWS account id the customer AWS trust policies + GCP WIF provider name. Defaults to Alethia's
# live account; override only if you run the platform in a different AWS account. (Azure/Alibaba don't
# use it — they trust the OIDC issuer, not this account.)
ALETHIA_AWS_ACCOUNT_ID=270587882865
# Azure is KEYLESS: register ONE multi-tenant Entra app with a federated-identity credential trusting
# the Alethia OIDC issuer (subject alethia-connector, audience api://AzureADTokenExchange) — no secret.
# The console + runner authenticate as this app via a minted assertion. Set only the app (client) id.
# HOW: `az ad app create --sign-in-audience AzureADMultipleOrgs` + `az ad app federated-credential create`
#      (exact commands in the docs) → the app (client) id.
ALETHIA_AZURE_CLIENT_ID=
# Alibaba is keyless + account-free: NOTHING to set here — the customer applies infra/connector/alibaba
# in their own account and connects with the role ARN. (Availability tracks the OIDC issuer key.)

# NOTE: AI (AI_GATEWAY_API_KEY) is intentionally NOT listed — the AI tier isn't monetized yet, so it
# stays off in prod on purpose. Add it here + an emit in deploy-console.yml only once AI is priced.

# ── Stripe (optional, hosted billing) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_TEAM=
# Metered prices for usage-based managed-runner minutes — without these, runner usage is metered
# but never charged. Create them as Stripe metered prices (event: alethia_runner_minutes).
STRIPE_PRICE_METER_TEAM=
STRIPE_PRICE_METER_ENTERPRISE=

# ── Support (optional) ───────────────────────────────────────────────────────
# Slack incoming-webhook URL — staff get pinged on a new support case / customer reply. Unset → no ping.
SUPPORT_SLACK_WEBHOOK_URL=
# Public community link (Discord/Slack/forum) on the in-app support page. Unset → the card is disabled.
NEXT_PUBLIC_COMMUNITY_URL=

# ── SES (optional, transactional email) ──────────────────────────────────────
ALETHIA_SES_REGION=
ALETHIA_SES_ACCESS_KEY_ID=
ALETHIA_SES_SECRET_ACCESS_KEY=

# ── Status page box (optional; only if you run infra/status) ─────────────────
# The status box uses direct Caddy TLS (not the tunnel), so it needs an ACME email.
ACME_EMAIL=

# ── Analytics (optional) ─────────────────────────────────────────────────────
# PostHog project API key (posthog.com, EU region) — the all-in-one suite hosted alethialabs.io runs
# (product analytics + session replay + web vitals + errors). Set this and leave Umami/OpenReplay unset.
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com   # optional — default is https://eu.i.posthog.com
# OpenReplay Cloud project key (openreplay.com, EU region). The tracker posts to OpenReplay Cloud's
# default ingest when NEXT_PUBLIC_OPENREPLAY_INGEST is empty. Optional OSS session-replay path;
# PostHog above is the prod suite.
NEXT_PUBLIC_OPENREPLAY_PROJECT_KEY=
# NEXT_PUBLIC_OPENREPLAY_INGEST=   # optional — empty = OpenReplay Cloud default; set for EU/self-host
