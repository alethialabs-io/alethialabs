{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "CommonJS",
		"moduleResolution": "node",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["../apps/console/*"]
		}
	},
	"include": ["src"]
}
