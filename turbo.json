{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": ["NODE_ENV"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"],
			"env": [
				"DOCS_URL",
				"ALETHIA_DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"ALETHIA_STORAGE_ENDPOINT",
				"ALETHIA_STORAGE_REGION",
				"ALETHIA_STORAGE_ACCESS_KEY_ID",
				"ALETHIA_STORAGE_SECRET_ACCESS_KEY",
				"CLI_JWT_SECRET",
				"INFRACOST_API_KEY",
				"GITLAB_APPLICATION_ID",
				"GITLAB_SECRET",
				"BITBUCKET_KEY",
				"BITBUCKET_SECRET",
				"RELEASE_API_SECRET"
			]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
