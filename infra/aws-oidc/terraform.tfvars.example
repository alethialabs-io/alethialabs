# Copy to terraform.tfvars (gitignored) or pass via TF_VAR_* env in the bootstrap
# workflow. Defaults already target the current repo + account.

github_repo   = "alethialabs-io/alethialabs" # after the org transfer
github_branch = "main"

# Runner ECR/ECS scoping (eu-west-1 dev fleet). Adjust when the fleet moves.
runner_aws_region     = "eu-west-1"
runner_ecr_repository = "alethia-runner-dev-runner"
runner_ecs_cluster    = "alethia-runner-dev-eu-west-1-cluster"
runner_ecs_service    = "alethia-runner-dev-eu-west-1-service"

# Optional: allow an admin principal to assume the roles for local apply.
# admin_principal_arns = ["arn:aws:iam::270587882865:role/YourAdminRole"]

# ── E2E nightly provisioning role (BYOC A1.1) ──
# The region the e2e nightly is hard-locked to (must NOT be a prod region). Default us-east-1.
# e2e_region = "us-east-1"
# The branch the nightly runs on (schedule ⇒ default branch). The OIDC sub binds exactly to it.
# e2e_github_branch = "main"
# Monthly cost ceiling (USD) — alerts at 50/80/100% actual + 100% forecast.
# e2e_monthly_budget_usd = 100
# Emails subscribed to the budget SNS topic + notified directly by the Budget.
e2e_budget_alert_emails = ["ops@alethialabs.io"]
