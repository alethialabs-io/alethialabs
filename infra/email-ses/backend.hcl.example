# AWS S3 state backend. Copy to backend.hcl (gitignored).
#   tofu init -backend-config=backend.hcl
#
# Auth comes from the AWS credential chain — admin locally, or the assumed
# alethia-ses-deployer OIDC role in CI. No static state keys.

bucket       = "alethia-tofu-state-270587882865"
key          = "ses/terraform.tfstate"
region       = "eu-central-1"
use_lockfile = true
