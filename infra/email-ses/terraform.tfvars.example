# Copy to terraform.tfvars (gitignored) or pass via TF_VAR_* env in CI / .env.
# AWS credentials come from the standard AWS_ACCESS_KEY_ID/SECRET env or profile
# — these must be ADMIN creds for the SES account (270587882865); the runtime
# send-only key cannot create anything.

cloudflare_api_token = "YOUR_CLOUDFLARE_API_TOKEN"
cloudflare_zone_id   = "YOUR_CLOUDFLARE_ZONE_ID"

aws_region = "eu-central-1"
domain     = "alethialabs.io"

# DMARC — start at none, tighten once aggregate reports look clean.
dmarc_policy = "none"
dmarc_rua    = "mailto:dmarc@alethialabs.io"

# Inbox for reputation alarms (leave "" to skip the email subscription).
alarm_email = "borislav@alethialabs.io"

# SNS posts bounce/complaint events here. Defaulted in variables.tf; override or
# set "" for a first apply before the console /api/webhooks/ses route is live.
events_webhook_url = "https://alethialabs.io/api/webhooks/ses"
