# Copy to terraform.tfvars (gitignored) or pass via TF_VAR_* env.
# Apply this stack ONCE with an admin/root identity for the SES account
# (270587882865) — it creates the OIDC provider + the least-priv deploy role.

aws_region = "eu-central-1"
domain     = "alethialabs.io"

# GitHub repo + branch whose Actions runs may assume the deploy role.
github_repo   = "bobikenobi12/bb-thesis-2026"
github_branch = "main"

# Set false (and fill oidc_provider_arn) if the account already has the GitHub
# Actions OIDC provider.
create_oidc_provider = true
# oidc_provider_arn  = "arn:aws:iam::270587882865:oidc-provider/token.actions.githubusercontent.com"

# Optional: let your admin user/role assume the deploy role for local import/apply.
# admin_principal_arns = ["arn:aws:iam::270587882865:user/you"]
