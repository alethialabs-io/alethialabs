# S3-compatible backend for the bootstrap state. Copy to backend.hcl (gitignored).
#   tofu init -backend-config=backend.hcl

bucket = "terraform-state"
key    = "ses-bootstrap/terraform.tfstate"
region = "us-east-1"

endpoints = {
  s3 = "https://YOUR_S3_ENDPOINT"
}

skip_credentials_validation = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_s3_checksum            = true
use_path_style              = true
use_lockfile                = true

# Credentials via env:
#   export AWS_ACCESS_KEY_ID="..."      # the TF_STATE_S3_* keys
#   export AWS_SECRET_ACCESS_KEY="..."
