#
# GitHub Actions OIDC provider — lets the deploy role be assumed by CI with no
# stored AWS keys. One per account; set create_oidc_provider = false to adopt an
# existing one. The thumbprint is fetched live so it stays correct if GitHub
# rotates its CA.

data "tls_certificate" "github" {
  count = var.create_oidc_provider ? 1 : 0
  url   = "https://token.actions.githubusercontent.com"
}

resource "aws_iam_openid_connect_provider" "github" {
  count           = var.create_oidc_provider ? 1 : 0
  url             = "https://token.actions.githubusercontent.com"
  client_id_list  = ["sts.amazonaws.com"]
  thumbprint_list = [data.tls_certificate.github[0].certificates[0].sha1_fingerprint]
  tags            = local.tags
}
