# Copy to terraform.tfvars (gitignored) or pass via TF_VAR_* env in CI.
# Azure provider auth comes from ARM_CLIENT_ID / ARM_CLIENT_SECRET /
# ARM_SUBSCRIPTION_ID / ARM_TENANT_ID (service principal).

location            = "westeurope"
resource_group_name = "alethia-cp"

cloudflare_api_token  = "YOUR_CLOUDFLARE_API_TOKEN" # DNS edit + Cloudflare Tunnel (Zero Trust) perms
cloudflare_zone_id    = "YOUR_CLOUDFLARE_ZONE_ID"
cloudflare_account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"
domain                = "alethialabs.io"

# There is no inbound SSH. Admin/deploy is via `az vm run-command`; interactive break-glass is the
# Azure Serial Console. This key is set for Serial-Console use only (never network-reachable).
ssh_public_key = "ssh-ed25519 AAAA... deploy@alethia"

vm_size      = "Standard_D2s_v5" # x86 Gen2, 2 vCPU / 8 GB
os_disk_size = 30

# Deployment environment tag (FinOps) — Dev, Stage, or Prod.
# environment = "Prod"
