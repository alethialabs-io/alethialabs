# Runner multi-environment deployment configuration
# Copy to terraform.tfvars and fill in secrets.

project_name = "alethia-runner"
environment  = "dev"

# Each entry creates a runner: VPC, ECS cluster, auto-registration.
# Key = runner name, region = AWS region, alethia_url = which Alethia it serves.
runners = {
  "prod-eu-west-1" = {
    region      = "eu-west-1"
    alethia_url = "https://alethialabs.io"
  }
  "beta-eu-west-1" = {
    region      = "eu-west-1"
    alethia_url = "https://beta.alethialabs.io"
  }
  "dev-eu-west-1" = {
    region      = "eu-west-1"
    alethia_url = "https://dev.alethialabs.io"
  }
}

runner_mode     = "cloud-hosted"
runner_version = "latest"

# Platform API secret — used by runners to auto-register and by the Lambda
# scaler to probe each runner's /api/platform/queue (console RELEASE_API_SECRET).
alethia_api_secret = ""

# S3-compatible state storage for provisioned specs (SeaweedFS / Garage / S3 / R2).
storage_endpoint          = "https://YOUR_S3_ENDPOINT"
storage_region            = "us-east-1"
storage_access_key_id     = ""
storage_secret_access_key = ""

# Infracost — cost estimation during plan jobs (optional).
infracost_api_key = ""
