# Tendril multi-environment deployment configuration
# Copy to terraform.tfvars and fill in secrets.

project_name = "tendril"
environment  = "dev"

# Each entry creates a tendril: VPC, ECS cluster, auto-registration.
# Key = tendril name, region = AWS region, trellis_url = which Trellis it serves.
tendrils = {
  "prod-eu-west-1" = {
    region      = "eu-west-1"
    trellis_url = "https://adp.prod.itgix.eu"
  }
  "beta-eu-west-1" = {
    region      = "eu-west-1"
    trellis_url = "https://beta.adp.itgix.com"
  }
  "dev-eu-west-1" = {
    region      = "eu-west-1"
    trellis_url = "https://your-ngrok-url.ngrok-free.dev"
  }
}

worker_mode     = "cloud-hosted"
tendril_version = "latest"

# Trellis API secret — used by tendrils to auto-register.
trellis_api_secret = ""

# Supabase API — used by the Lambda scaler to query queued jobs.
supabase_url              = "https://YOUR_PROJECT.supabase.co"
supabase_service_role_key = ""

# S3-compatible state storage for provisioned vines (SeaweedFS / Garage / S3 / R2).
storage_endpoint          = "https://YOUR_S3_ENDPOINT"
storage_region            = "us-east-1"
storage_access_key_id     = ""
storage_secret_access_key = ""

# Infracost — cost estimation during plan jobs (optional).
infracost_api_key = ""
