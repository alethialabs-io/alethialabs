# AWS-native S3 backend. Copy to backend.hcl (gitignored).
#
#   tofu init -backend-config=backend.hcl
#
# In CI the apply job assumes the alethia-cp-deployer OIDC role (infra/aws-oidc), which
# authenticates this backend natively — no static state keys. Locally, use your AWS SSO
# / env creds (or assume the role).

bucket       = "alethia-tofu-state-270587882865"
key          = "hetzner/terraform.tfstate"
region       = "eu-central-1"
use_lockfile = true
