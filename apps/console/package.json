{
	"name": "console",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node ../../scripts/sync-public-assets.mjs && node scripts/gen-docs-index.mjs && next dev --turbopack ",
		"build": "node ../../scripts/sync-public-assets.mjs && node scripts/gen-docs-index.mjs && next build",
		"start": "next start",
		"lint": "eslint .",
		"check-types": "tsc --noEmit",
		"check:no-supabase": "node scripts/check-no-supabase-data.mjs",
		"check:ee-boundary": "node scripts/check-ee-boundary.mjs",
		"check:authz-scope": "node scripts/check-authz-scope.mjs",
		"check:marketing-routes": "node scripts/check-marketing-routes.mjs",
		"check:migrations": "node scripts/check-migrations.mjs",
		"gen:connectors": "node scripts/gen-connectors.mjs",
		"gen:docs-index": "node scripts/gen-docs-index.mjs",
		"gen:catalog": "node scripts/gen-catalog.mjs",
		"gen:cli-fixtures": "tsx scripts/gen-cli-fixtures.ts",
		"gen:go-enums": "tsx scripts/gen-go-enums.ts",
		"db:generate": "bash ../../scripts/db-generate.sh",
		"db:migrate": "node scripts/migrate.mjs",
		"db:reset": "node scripts/reset.mjs && node scripts/migrate.mjs",
		"db:studio": "drizzle-kit studio",
		"stripe:setup": "tsx scripts/stripe-setup.ts",
		"org:set-plan": "node scripts/set-org-plan.mjs",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:ai-eval": "vitest run --config vitest.ai-eval.config.ts",
		"mutate": "stryker run",
		"mutate:since": "stryker run --since origin/main",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"email:dev": "email dev --dir emails --port 3001",
		"email:export": "email export --dir emails --outDir .react-email-out"
	},
