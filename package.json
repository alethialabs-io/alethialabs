{
	"name": "alethialabs",
	"private": true,
	"license": "AGPL-3.0-only",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:console": "turbo run dev --filter=console",
		"dev:up": "bash scripts/dev-up.sh",
		"dev:logs": "touch /tmp/alethia-dev-console.log && tail -n +1 -f /tmp/alethia-dev-console.log",
		"dev:tunnel": "bash scripts/cf-tunnel.sh",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"db:up": "bash scripts/db-bootstrap.sh",
		"db:reset": "docker compose down -v && bash scripts/db-bootstrap.sh",
		"compose:up": "bash scripts/compose-up.sh",
		"compose:up:full": "bash scripts/compose-up.sh caddy app docs blog runner",
		"compose:up:site": "COMPOSE_PROFILES=marketing bash scripts/compose-up.sh caddy app docs blog marketing",
		"compose:ps": "docker compose ps",
		"compose:logs": "docker compose logs -f --tail=100",
		"compose:down": "docker compose down"
	},
	"devDependencies": {
		"prettier": "^3.6.2",
		"turbo": "^2.6.3",
		"typescript": "5.9.2"
	},
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"overrides": {
			"react": "19.2.3",
			"react-dom": "19.2.3",
			"@types/react": "19.2.8",
			"@types/react-dom": "19.2.3",
			"zod": "4.4.3"
		}
	}
}
